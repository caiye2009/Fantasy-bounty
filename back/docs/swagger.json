{
    "swagger": "2.0",
    "info": {
        "description": "极绎贸易招投标系统对外接口",
        "title": "Fantasy Bounty API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/api/v1",
    "paths": {
        "/api/v1/auth/send-code": {
            "post": {
                "description": "向手机号发送登录/注册验证码",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "发送验证码",
                "parameters": [
                    {
                        "description": "手机号",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/auth.SendCodeRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/auth.SendCodeResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/auth.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/auth/verify-code": {
            "post": {
                "description": "通过手机号和验证码进行登录，若手机号未注册则自动注册",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "验证码登录/注册",
                "parameters": [
                    {
                        "description": "手机号和验证码",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/auth.VerifyCodeRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/auth.VerifyCodeResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/auth.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/auth.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/bids": {
            "get": {
                "description": "根据赏金ID获取竞标列表",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "bid"
                ],
                "summary": "获取竞标列表",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "赏金ID",
                        "name": "bounty_id",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "default": 1,
                        "description": "页码",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 10,
                        "description": "每页数量",
                        "name": "page_size",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/bid.BidListResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/bid.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/bid.ErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "为指定赏金创建竞标",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "bid"
                ],
                "summary": "创建竞标",
                "parameters": [
                    {
                        "description": "竞标信息",
                        "name": "bid",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/bid.CreateBidRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/bid.BidResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/bid.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/bids/my": {
            "get": {
                "description": "获取当前用户的竞标列表",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "bid"
                ],
                "summary": "获取我的竞标列表",
                "parameters": [
                    {
                        "type": "string",
                        "description": "状态筛选: draft, pending, in_progress, pending_acceptance, completed",
                        "name": "status",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 1,
                        "description": "页码",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 10,
                        "description": "每页数量",
                        "name": "page_size",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/bid.BidListResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/bid.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/bid.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/bids/{id}": {
            "delete": {
                "description": "删除指定竞标",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "bid"
                ],
                "summary": "删除竞标",
                "parameters": [
                    {
                        "type": "string",
                        "description": "竞标ID (UUID)",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/bid.ErrorResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/bid.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/bid.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/internal/login": {
            "post": {
                "description": "将登录请求转发到内部系统，返回内部系统的token",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "内部系统登录",
                "parameters": [
                    {
                        "description": "工号和密码",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/auth.InternalLoginRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/auth.ErrorResponse"
                        }
                    },
                    "502": {
                        "description": "Bad Gateway",
                        "schema": {
                            "$ref": "#/definitions/auth.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/proxy/bind-wechat": {
            "post": {
                "description": "验证供应商身份并绑定 OpenId，成功后 isSucceed=true",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "proxy"
                ],
                "summary": "微信端绑定供应商",
                "parameters": [
                    {
                        "description": "绑定参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/proxy.BindWeChatRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/proxy.BindWeChatResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/proxy.BaseResponse"
                        }
                    }
                }
            }
        },
        "/proxy/get-by-wechat": {
            "post": {
                "description": "data 有数据=已绑定供应商；data 为空数组=未绑定；isSucceed=false 看 message",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "proxy"
                ],
                "summary": "根据 Openid 获取供应商信息",
                "parameters": [
                    {
                        "description": "查询参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/proxy.GetByWeChatRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/proxy.GetByWeChatResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/proxy.BaseResponse"
                        }
                    }
                }
            }
        },
        "/proxy/inquiry-detail": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "proxy"
                ],
                "summary": "供应商查看采购需求详情及报价情况",
                "parameters": [
                    {
                        "description": "查询参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/proxy.InquiryDetailRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/proxy.InquiryDetailResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/proxy.BaseResponse"
                        }
                    }
                }
            }
        },
        "/proxy/inquiry-query": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "proxy"
                ],
                "summary": "查询供应商可报价的招标信息",
                "parameters": [
                    {
                        "description": "查询参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/proxy.InquiryQueryRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/proxy.InquiryQueryResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/proxy.BaseResponse"
                        }
                    }
                }
            }
        },
        "/proxy/quote-delete": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "proxy"
                ],
                "summary": "撤回或删除供应商报价",
                "parameters": [
                    {
                        "description": "操作参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/proxy.QuoteDeleteRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/proxy.QuoteDeleteResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/proxy.BaseResponse"
                        }
                    }
                }
            }
        },
        "/proxy/quote-save": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "proxy"
                ],
                "summary": "供应商提交或保存报价",
                "parameters": [
                    {
                        "description": "报价参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/proxy.QuoteSaveRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/proxy.QuoteSaveResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/proxy.BaseResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "auth.ErrorResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "auth.InternalLoginRequest": {
            "type": "object",
            "required": [
                "password",
                "username"
            ],
            "properties": {
                "password": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "auth.SendCodeRequest": {
            "type": "object",
            "required": [
                "phone"
            ],
            "properties": {
                "phone": {
                    "type": "string"
                }
            }
        },
        "auth.SendCodeResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "auth.VerifyCodeRequest": {
            "type": "object",
            "required": [
                "code",
                "phone"
            ],
            "properties": {
                "code": {
                    "type": "string"
                },
                "phone": {
                    "type": "string"
                }
            }
        },
        "auth.VerifyCodeResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "isNewUser": {
                    "description": "是否新用户（首次注册）",
                    "type": "boolean"
                },
                "message": {
                    "type": "string"
                },
                "token": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "bid.Bid": {
            "type": "object",
            "properties": {
                "bidPrice": {
                    "description": "投标价格",
                    "type": "number"
                },
                "bountyId": {
                    "type": "integer"
                },
                "createdAt": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "knittedSpec": {
                    "$ref": "#/definitions/bid.BidKnittedSpec"
                },
                "status": {
                    "description": "pending, in_progress, pending_acceptance, completed",
                    "type": "string"
                },
                "updatedAt": {
                    "type": "string"
                },
                "username": {
                    "description": "关联用户名",
                    "type": "string"
                },
                "wovenSpec": {
                    "description": "关联规格 - 根据悬赏类型只会有一个有值",
                    "allOf": [
                        {
                            "$ref": "#/definitions/bid.BidWovenSpec"
                        }
                    ]
                }
            }
        },
        "bid.BidKnittedSpec": {
            "type": "object",
            "properties": {
                "bidId": {
                    "type": "string"
                },
                "deliveryMethod": {
                    "description": "交货方式",
                    "type": "string"
                },
                "greigeDeliveryDate": {
                    "description": "胚布交期",
                    "type": "string"
                },
                "greigeFabricType": {
                    "description": "胚布类型（现货/定织）",
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "sizeWeight": {
                    "description": "尺码（重量/皮重）",
                    "type": "number"
                }
            }
        },
        "bid.BidListResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/bid.Bid"
                    }
                },
                "message": {
                    "type": "string"
                },
                "total": {
                    "type": "integer"
                }
            }
        },
        "bid.BidResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {
                    "$ref": "#/definitions/bid.Bid"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "bid.BidWovenSpec": {
            "type": "object",
            "properties": {
                "bidId": {
                    "type": "string"
                },
                "deliveryMethod": {
                    "description": "交货方式",
                    "type": "string"
                },
                "greigeDeliveryDate": {
                    "description": "胚布交期",
                    "type": "string"
                },
                "greigeFabricType": {
                    "description": "胚布类型（现货/定织）",
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "sizeLength": {
                    "description": "尺码（长度）",
                    "type": "number"
                }
            }
        },
        "bid.CreateBidKnittedSpecRequest": {
            "type": "object",
            "properties": {
                "deliveryMethod": {
                    "description": "竞标确认后 / 签订合同后 / 收到预付款后",
                    "type": "string"
                },
                "greigeDeliveryDate": {
                    "type": "string"
                },
                "greigeFabricType": {
                    "description": "现货 / 定织",
                    "type": "string"
                },
                "sizeWeight": {
                    "type": "number"
                }
            }
        },
        "bid.CreateBidRequest": {
            "type": "object",
            "required": [
                "bidPrice",
                "bountyId"
            ],
            "properties": {
                "bidPrice": {
                    "type": "number"
                },
                "bountyId": {
                    "type": "integer"
                },
                "knittedSpec": {
                    "$ref": "#/definitions/bid.CreateBidKnittedSpecRequest"
                },
                "wovenSpec": {
                    "$ref": "#/definitions/bid.CreateBidWovenSpecRequest"
                }
            }
        },
        "bid.CreateBidWovenSpecRequest": {
            "type": "object",
