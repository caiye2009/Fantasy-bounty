                },
                "greigeDeliveryDate": {
                    "type": "string"
                },
                "greigeFabricType": {
                    "description": "现货 / 定织",
                    "type": "string"
                },
                "sizeLength": {
                    "type": "number"
                }
            }
        },
        "bid.ErrorResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "proxy.BaseResponse": {
            "type": "object",
            "properties": {
                "data": {},
                "isSucceed": {
                    "type": "boolean"
                },
                "message": {
